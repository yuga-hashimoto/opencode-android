<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext is required for localhost local runtime and LAN/Tailscale HTTP.
  App-layer OpenCodeUrl.isTrustedCleartextHost is the authoritative host gate;
  Android NSC cannot express RFC1918/Tailscale IP ranges as domain rules.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">local</domain>
    </domain-config>
</network-security-config>
